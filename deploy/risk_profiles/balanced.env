# Balanced profile: default production baseline for mixed known + novel threat coverage.
RISK_SCORING_ENABLED=true
RISK_WEIGHT_XGBOOST=0.55
RISK_WEIGHT_ANOMALY=0.30
RISK_WEIGHT_DRIFT=0.15
RISK_MIN_COMPONENT_SCORE=0.50
RISK_ALERT_THRESHOLD=0.75
RISK_ALERT_MIN_SIGNALS=1
RISK_AUTOBLOCK_ENABLED=false
RISK_AUTOBLOCK_THRESHOLD=0.92
RISK_AUTOBLOCK_MIN_SIGNALS=2
RISK_AUTOBLOCK_TTL_SECONDS=300
