# Aggressive profile: higher zero-day sensitivity with lower alert threshold and stronger anomaly weighting.
RISK_SCORING_ENABLED=true
RISK_WEIGHT_XGBOOST=0.40
RISK_WEIGHT_ANOMALY=0.45
RISK_WEIGHT_DRIFT=0.15
RISK_MIN_COMPONENT_SCORE=0.45
RISK_ALERT_THRESHOLD=0.65
RISK_ALERT_MIN_SIGNALS=1
RISK_AUTOBLOCK_ENABLED=false
RISK_AUTOBLOCK_THRESHOLD=0.88
RISK_AUTOBLOCK_MIN_SIGNALS=2
RISK_AUTOBLOCK_TTL_SECONDS=300
