# Conservative profile: lowest false-positive pressure, strongest confidence requirements.
RISK_SCORING_ENABLED=true
RISK_WEIGHT_XGBOOST=0.70
RISK_WEIGHT_ANOMALY=0.20
RISK_WEIGHT_DRIFT=0.10
RISK_MIN_COMPONENT_SCORE=0.60
RISK_ALERT_THRESHOLD=0.85
RISK_ALERT_MIN_SIGNALS=2
RISK_AUTOBLOCK_ENABLED=false
RISK_AUTOBLOCK_THRESHOLD=0.97
RISK_AUTOBLOCK_MIN_SIGNALS=3
RISK_AUTOBLOCK_TTL_SECONDS=300
