{
  "dashboard": {
    "id": null,
    "title": "Enhanced IDS/IPS System Dashboard",
    "tags": ["ids", "ips", "security"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "System Overview",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"enhanced-ids-ips\"}",
            "legendFormat": "System Status"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "options": {
                  "0": {
                    "text": "Down"
                  },
                  "1": {
                    "text": "Up"
                  }
                },
                "type": "value"
              }
            ],
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": 0
                },
                {
                  "color": "green",
                  "value": 1
                }
              ]
            },
            "unit": "none"
          }
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Packets Processed",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(ids_packets_processed_total[5m])",
            "legendFormat": "Packets/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "pps",
            "mappings": [],
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 500
                },
                {
                  "color": "red",
                  "value": 1000
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 4,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Alerts Generated",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(ids_alerts_generated_total[5m])",
            "legendFormat": "Alerts/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "alerts/sec",
            "mappings": [],
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 5
                },
                {
                  "color": "red",
                  "value": 10
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 8,
          "y": 0
        }
      },
      {
        "id": 4,
        "title": "Blocked IPs",
        "type": "stat",
        "targets": [
          {
            "expr": "ids_blocked_ips",
            "legendFormat": "Blocked IPs"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "mappings": [],
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 50
                },
                {
                  "color": "red",
                  "value": 100
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 5,
        "title": "Active Connections",
        "type": "stat",
        "targets": [
          {
            "expr": "ids_active_connections",
            "legendFormat": "Active Connections"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "mappings": [],
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 25
                },
                {
                  "color": "red",
                  "value": 50
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 16,
          "y": 0
        }
      },
      {
        "id": 6,
        "title": "Detection Latency",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, ids_detection_latency_seconds_bucket)",
            "legendFormat": "95th Percentile"
          },
          {
            "expr": "histogram_quantile(0.50, ids_detection_latency_seconds_bucket)",
            "legendFormat": "50th Percentile"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "mappings": []
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 4
        }
      },
      {
        "id": 7,
        "title": "Packets Processed Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(ids_packets_processed_total[5m])",
            "legendFormat": "Total"
          },
          {
            "expr": "sum by (detector) (rate(ids_packets_processed_total[5m]))",
            "legendFormat": "{{ detector }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "pps",
            "mappings": []
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 4
        }
      },
      {
        "id": 8,
        "title": "Alerts by Type",
        "type": "piechart",
        "targets": [
          {
            "expr": "topk(10, sum by (attack_type) (rate(ids_alerts_generated_total[1h])))",
            "legendFormat": "{{ attack_type }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "mappings": []
          }
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 12
        }
      },
      {
        "id": 9,
        "title": "Mitigation Actions",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(ids_mitigation_actions_total[5m])",
            "legendFormat": "Total"
          },
          {
            "expr": "rate(ids_mitigation_actions_total{action=\"block_ip\"}[5m])",
            "legendFormat": "Block IP"
          },
          {
            "expr": "rate(ids_mitigation_actions_total{action=\"isolate_node\"}[5m])",
            "legendFormat": "Isolate Node"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "actions/sec",
            "mappings": []
          }
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 8,
          "y": 12
        }
      },
      {
        "id": 10,
        "title": "Model Predictions",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(ids_model_predictions_total[5m])",
            "legendFormat": "Total"
          },
          {
            "expr": "rate(ids_model_predictions_total{prediction=\"malicious\"}[5m])",
            "legendFormat": "Malicious"
          },
          {
            "expr": "rate(ids_model_predictions_total{prediction=\"benign\"}[5m])",
            "legendFormat": "Benign"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "predictions/sec",
            "mappings": []
          }
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 16,
          "y": 12
        }
      },
      {
        "id": 11,
        "title": "Top Attackers",
        "type": "table",
        "targets": [
          {
            "expr": "topk(10, sum by (source_ip) (rate(ids_alerts_generated_total[1h])))",
            "legendFormat": "{{ source_ip }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "mappings": []
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 20
        }
      },
      {
        "id": 12,
        "title": "System Resources",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(node_cpu_seconds_total[5m])",
            "legendFormat": "CPU"
          },
          {
            "expr": "node_memory_MemAvailable_bytes",
            "legendFormat": "Memory Available"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "mappings": []
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 20
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": [
        "5s",
        "10s",
        "30s",
        "1m",
        "5m",
        "15m",
        "30m",
        "1h",
        "2h",
        "1d"
      ]
    },
    "templating": {
      "list": []
    },
    "annotations": {
      "list": [
        {
          "builtIn": 1,
          "datasource": "-- Grafana --",
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "type": "dashboard"
        }
      ]
    },
    "refresh": "5s",
    "schemaVersion": 22,
    "version": 1,
    "links": []
  }
}
