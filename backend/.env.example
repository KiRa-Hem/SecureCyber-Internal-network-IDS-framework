# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=false

# MongoDB credentials
MONGODB_URI=mongodb://localhost:27017/ids
MONGO_DB=ids
MONGO_USER=
MONGO_PASSWORD=
MONGO_CLUSTER=

# Packet Capture
ENABLE_PACKET_CAPTURE=true
NETWORK_INTERFACE=Wi-Fi
CAPTURE_FILTER=tcp or udp and not multicast and not broadcast

# Redis
ENABLE_REDIS=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Detection
CONFIDENCE_THRESHOLD=0.98
MODEL_PATH=../models
RETRAIN_THRESHOLD=100
ENABLE_SIMULATION=false
ENABLE_ANOMALY_DETECTION=true
ANOMALY_SCORE_THRESHOLD=-0.15
ANOMALY_CONTAMINATION=0.01
ANOMALY_WARMUP_SAMPLES=500

# Mitigation
ENABLE_REAL_MITIGATION=false
MITIGATION_CONFIRMATION_TOKEN=
BLOCK_DURATION=300

# Sensors
SENSOR_LOCATIONS=["edge", "internal"]

# Security
PAYLOAD_SNIPPET_MAX=512
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
API_TOKEN=CHANGE_ME
ADMIN_TOKEN=CHANGE_ME
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_ISSUER=securecyber-ids
JWT_AUDIENCE=securecyber-ui
JWT_EXP_SECONDS=3600
CORS_ORIGINS=["http://localhost","http://127.0.0.1","http://localhost:80","http://127.0.0.1:80","http://localhost:5173","http://127.0.0.1:5173"]
CORS_ALLOW_CREDENTIALS=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ids.log
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE=logs/audit.log
AUDIT_LOG_TO_DB=true
ALERT_DEDUP_WINDOW_SECONDS=30
ALERT_FUSION_ENABLED=true
DRIFT_ENABLED=true
DRIFT_WINDOW_SIZE=500
DRIFT_Z_THRESHOLD=3.0
DRIFT_MIN_FEATURES=4
DRIFT_COOLDOWN_SECONDS=300
