# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=false

# MongoDB credentials
MONGODB_URI=mongodb://localhost:27017/ids
MONGO_DB=ids
MONGO_USER=
MONGO_PASSWORD=
MONGO_CLUSTER=

# Packet Capture
ENABLE_PACKET_CAPTURE=true
NETWORK_INTERFACE=Wi-Fi
CAPTURE_FILTER=tcp or udp and not multicast and not broadcast

# Redis
ENABLE_REDIS=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Detection
CONFIDENCE_THRESHOLD=0.98
MODEL_PATH=../models
RETRAIN_THRESHOLD=100
ENABLE_SIMULATION=false
ENABLE_ANOMALY_DETECTION=true
ANOMALY_SCORE_THRESHOLD=-0.15
ANOMALY_CONTAMINATION=0.01
ANOMALY_WARMUP_SAMPLES=500
# Combined risk scoring (xgboost + anomaly + drift)
RISK_SCORING_ENABLED=true
RISK_WEIGHT_XGBOOST=0.55
RISK_WEIGHT_ANOMALY=0.30
RISK_WEIGHT_DRIFT=0.15
RISK_MIN_COMPONENT_SCORE=0.5
RISK_ALERT_THRESHOLD=0.75
RISK_ALERT_MIN_SIGNALS=1
RISK_AUTOBLOCK_ENABLED=false
RISK_AUTOBLOCK_THRESHOLD=0.92
RISK_AUTOBLOCK_MIN_SIGNALS=2
RISK_AUTOBLOCK_TTL_SECONDS=300

# Mitigation
ENABLE_REAL_MITIGATION=false
MITIGATION_CONFIRMATION_TOKEN=
BLOCK_DURATION=300

# Sensors
SENSOR_LOCATIONS=["edge", "internal"]

# Security
PAYLOAD_SNIPPET_MAX=512
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
API_TOKEN=replace-with-random-viewer-token
ADMIN_TOKEN=replace-with-random-admin-token
JWT_SECRET=replace-with-random-jwt-secret
AUTH_ALLOW_INSECURE_NO_AUTH=false
DEMO_LOGIN_USERNAME=demo_user
DEMO_LOGIN_PASSWORD=replace-with-demo-password
JWT_ALGORITHM=HS256
JWT_ISSUER=securecyber-ids
JWT_AUDIENCE=securecyber-ui
JWT_EXP_SECONDS=3600
XGBOOST_MIN_RUNTIME_THRESHOLD=0.5
CORS_ORIGINS=["http://localhost","http://127.0.0.1","http://localhost:80","http://127.0.0.1:80","http://localhost:5173","http://127.0.0.1:5173"]
CORS_ALLOW_CREDENTIALS=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ids.log
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE=logs/audit.log
AUDIT_LOG_TO_DB=true
ALERT_DEDUP_WINDOW_SECONDS=30
ALERT_FUSION_ENABLED=true
DRIFT_ENABLED=true
DRIFT_WINDOW_SIZE=500
DRIFT_Z_THRESHOLD=3.0
DRIFT_MIN_FEATURES=4
DRIFT_COOLDOWN_SECONDS=300
